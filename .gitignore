# ─────────────────────────────────────────────────────────
# SECURITY — never commit these
# ─────────────────────────────────────────────────────────

# Private keys
private_key.pem
pki/private_key.pem
*_private*.pem
*.key

# Signature files (generated artifacts — never commit)
*.sig

# Environment variable files
.env
.env.*
.env.local


# ─────────────────────────────────────────────────────────
# SAFE TO COMMIT — explicit exceptions
# ─────────────────────────────────────────────────────────

# Public key is safe to commit
!pki/public_key.pem

# Keep .gitkeep files in tracked empty directories
!edge_agent/downloads/.gitkeep
!edge_agent/rejections/.gitkeep


# ─────────────────────────────────────────────────────────
# GENERATED ARTIFACTS — do not commit
# ─────────────────────────────────────────────────────────

# Firmware binaries (generated by create_dummy_firmware.py)
# Exception: committed reference binary in firmware/
*.bin
!firmware/dummy_firmware_v1.0.0.bin

# Downloads folder contents (downloaded at runtime)
edge_agent/downloads/*

# Rejection reports (generated at runtime)
edge_agent/rejections/*.json

# Test artifact binaries (generated by test fixtures)
firmware/dummy_firmware_v*.*.*.bin
!firmware/dummy_firmware_v1.0.0.bin


# ─────────────────────────────────────────────────────────
# PYTHON ARTIFACTS
# ─────────────────────────────────────────────────────────

__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
dist/
build/
*.egg-info/
.pytest_cache/
.coverage
htmlcov/


# ─────────────────────────────────────────────────────────
# OS AND IDE FILES
# ─────────────────────────────────────────────────────────

.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp